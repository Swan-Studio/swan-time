# Copy to .env.local. Loaded automatically by the main process at startup.
# Real .env.local is gitignored.

# Shared Anthropic key — used for AI features when a user enables them in
# Settings and hasn't pasted their own personal key. The team uses one
# account; rotate at console.anthropic.com if leaked.
SWAN_ANTHROPIC_KEY=

# Monday OAuth (optional — manual API token works too). Register an app at
# https://auth.monday.com/admin/integrations/apps with redirect
# swan-time://oauth/callback
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
